#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local src="$1"
  if command -v readlink >/dev/null 2>&1; then
    local resolved=""
    resolved="$(readlink -f "$src" 2>/dev/null || true)"
    if [[ -n "$resolved" ]]; then
      echo "$resolved"
      return 0
    fi
  fi
  echo "$src"
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

if [[ -x "$SCRIPT_DIR/ptbd-gui.py" ]]; then
  exec python3 "$SCRIPT_DIR/ptbd-gui.py" "$@"
fi

if command -v python3 >/dev/null 2>&1 && [[ -f "$SCRIPT_DIR/ptbd-gui.py" ]]; then
  exec python3 "$SCRIPT_DIR/ptbd-gui.py" "$@"
fi

echo "[ERROR] 找不到 ptbd-gui.py 或 python3" >&2
exit 1
