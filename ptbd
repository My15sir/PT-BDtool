#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BDTOOL_ROOT="$ROOT_DIR"
export BDTOOL_ROOT
export BDTOOL_NO_PROMPT="${BDTOOL_NO_PROMPT:-1}"
export BDTOOL_CMD_TIMEOUT="${BDTOOL_CMD_TIMEOUT:-300}"

# shellcheck source=lib/ui.sh
source "$ROOT_DIR/lib/ui.sh"
ensure_log_dir "$ROOT_DIR"
setup_log_redirection "$ROOT_DIR"

usage() {
  cat <<'USAGE'
ptbd <command> [options]

commands:
  install [--apply] [--with-deps] [--lang zh|en]
  doctor
  scan [path] [--full] [extra bdtool scan args]
  clean
  --help

examples:
  ./ptbd install
  ./ptbd install --apply --with-deps
  ./ptbd doctor
  ./ptbd scan
  ./ptbd scan /data/videos --full
  ./ptbd clean
USAGE
}

cmd_install() {
  local apply="0"
  local with_deps="0"
  local lang="${BDTOOL_LANG:-en}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --apply) apply="1"; shift ;;
      --with-deps) with_deps="1"; shift ;;
      --lang)
        [[ $# -ge 2 ]] || die "--lang requires zh|en"
        lang="$2"
        shift 2
        ;;
      --lang=*)
        lang="${1#*=}"
        shift
        ;;
      *)
        die "unknown install option: $1"
        ;;
    esac
  done

  section "Install Stage"
  log_info "No-prompt mode: $BDTOOL_NO_PROMPT"

  local writable="yes"
  [[ -w "$ROOT_DIR" ]] || writable="no"
  log_info "workspace writable: $writable"

  for c in bash ffmpeg ffprobe mediainfo BDInfo; do
    if command -v "$c" >/dev/null 2>&1; then
      log_success "dep ok: $c"
    else
      log_warn "dep miss: $c"
    fi
  done

  if [[ "$apply" != "1" ]]; then
    execute_with_spinner "install dry-run checks" "$ROOT_DIR/install.sh" --dry-run --lang "$lang" || die "install dry-run failed"
    return 0
  fi

  if [[ "$with_deps" == "1" ]]; then
    execute_with_spinner "apply install with deps" "$ROOT_DIR/install.sh" -k --lang "$lang" || die "install apply failed"
  else
    execute_with_spinner "apply install" "$ROOT_DIR/install.sh" --lang "$lang" || die "install apply failed"
  fi
}

cmd_doctor() {
  section "Doctor Stage"
  execute_with_spinner "run doctor" "$ROOT_DIR/bdtool.sh" doctor || die "doctor failed"
}

cmd_scan() {
  section "Scan Stage"
  local scan_path=""
  local full="0"
  local passthrough=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --full)
        full="1"
        shift
        ;;
      --*)
        passthrough+=("$1")
        if [[ $# -ge 2 && "${2:0:1}" != "-" ]]; then
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      *)
        if [[ -z "$scan_path" ]]; then
          scan_path="$1"
        else
          passthrough+=("$1")
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$scan_path" ]]; then
    scan_path="$ROOT_DIR/bdtool-output/smoke-input/demo.mkv"
    mkdir -p "$(dirname "$scan_path")"
    : > "$scan_path"
    log_info "no path provided, use smoke input: $scan_path"
  fi

  if [[ "$full" == "1" ]]; then
    execute_with_spinner "scan full" "$ROOT_DIR/bdtool.sh" "$scan_path" "${passthrough[@]}" || die "scan failed"
  else
    execute_with_spinner "scan dry" "$ROOT_DIR/bdtool.sh" "$scan_path" --mode dry "${passthrough[@]}" || die "scan failed"
  fi
}

cmd_clean() {
  section "Clean Stage"
  execute_with_spinner "clean outputs" "$ROOT_DIR/bdtool.sh" clean || die "clean failed"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    install)
      shift
      cmd_install "$@"
      ;;
    doctor)
      shift
      cmd_doctor "$@"
      ;;
    scan)
      shift
      cmd_scan "$@"
      ;;
    clean)
      shift
      cmd_clean "$@"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      usage
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
