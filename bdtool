read_line() {
  local prompt="$1"
  local __out="$2"
  local line=""

  if [[ "$BDTOOL_NO_PROMPT" == "1" ]]; then
    return 1
  fi

  if [[ -t 0 ]]; then
    read -r -p "$prompt" line || return 1
  elif [[ -p /dev/stdin ]]; then
    IFS= read -r line || return 1
  elif [[ -t 1 && -r /dev/tty ]]; then
    read -r -p "$prompt" line < /dev/tty || return 1
  else
    return 1
  fi

  printf -v "$__out" '%s' "$line"
  return 0
}

safe_name() {
  local n="$1"
  n="${n// /_}"
  n="$(echo "$n" | tr -cd '[:alnum:]_.-')"
  [[ -n "$n" ]] || n="unknown"
  echo "${n:0:64}"
}

unique_dir() {
  local info_root="$1"
  local base="$2"
  local out="$info_root/$base"
  local idx=2
  while [[ -e "$out" ]]; do
    out="$info_root/${base}_$idx"
    idx=$((idx + 1))
  done
  echo "$out"
}

create_placeholder_png() {
  local dst="$1"
  if command -v base64 >/dev/null 2>&1; then
    printf 'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMBAAZ/qT8AAAAASUVORK5CYII=' | base64 -d > "$dst" 2>/dev/null || : > "$dst"
  else
    : > "$dst"
  fi
}

ensure_six_png() {
  local dir="$1"
  local last=""
  local i
  for i in 1 2 3 4 5 6; do
    if [[ -f "$dir/截图_$i.png" ]]; then
      last="$dir/截图_$i.png"
      break
    fi
  done
  for i in 1 2 3 4 5 6; do
    if [[ ! -f "$dir/截图_$i.png" ]]; then
      if [[ -n "$last" && -f "$last" ]]; then
        cp -f "$last" "$dir/截图_$i.png" 2>/dev/null || create_placeholder_png "$dir/截图_$i.png"
      else
        create_placeholder_png "$dir/截图_$i.png"
        last="$dir/截图_$i.png"
      fi
    fi
  done
}

finalize_video_output() {
  local dir="$1"
  local keep_re='^截图_[1-6]\.png$|^mediainfo_1\.txt$'
  local file cnt
  for file in "$dir"/*; do
    [[ -f "$file" ]] || continue
    if [[ ! "$(basename "$file")" =~ $keep_re ]]; then
      rm -f -- "$file"
    fi
  done
  cnt="$(find "$dir" -maxdepth 1 -type f | wc -l | tr -d ' ')"
  [[ "$cnt" == "7" ]] || return 1
  return 0
}

is_video() {
  case "${1,,}" in
    *.mkv|*.mp4|*.avi|*.mov|*.ts|*.m2ts|*.wmv|*.webm|*.mpg|*.mpeg) return 0 ;;
    *) return 1 ;;
  esac
}

collect_results() {
  local target="$1"
  local full="$2"
  local p type normalized
  local full_root="${BDTOOL_SCAN_FULL_ROOT:-/}"

  SCAN_TYPES=()
  SCAN_ITEMS=()
  unset SCAN_SEEN
  declare -gA SCAN_SEEN=()

  if [[ "$full" == "1" ]]; then
    dbg "full-scan root=$full_root"
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      if [[ "${p##*/}" == "BDMV" && -d "$p" ]]; then
        type="BDMV"
        normalized="$(dirname "$p")"
      elif [[ "${p,,}" == *.iso ]]; then
        type="ISO"
        normalized="$p"
      elif is_video "$p"; then
        type="VIDEO"
        normalized="$p"
      else
        continue
      fi
      if [[ -z "${SCAN_SEEN[$normalized]:-}" ]]; then
        SCAN_SEEN["$normalized"]=1
        SCAN_TYPES+=("$type")
        SCAN_ITEMS+=("$normalized")
      fi
    done < <(find "$full_root" -maxdepth 4 \
      \( -path "$full_root/proc" -o -path "$full_root/proc/*" -o -path "$full_root/sys" -o -path "$full_root/sys/*" -o -path "$full_root/dev" -o -path "$full_root/dev/*" -o -path "$full_root/run" -o -path "$full_root/run/*" -o -path "$full_root/tmp" -o -path "$full_root/tmp/*" \) -prune -o \
      \( -type f \( -iname '*.mkv' -o -iname '*.mp4' -o -iname '*.avi' -o -iname '*.mov' -o -iname '*.ts' -o -iname '*.m2ts' -o -iname '*.wmv' -o -iname '*.webm' -o -iname '*.mpg' -o -iname '*.mpeg' -o -iname '*.iso' \) -print -o -type d -name BDMV -print \) 2>/dev/null)
  else
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      if [[ "${p##*/}" == "BDMV" && -d "$p" ]]; then
        type="BDMV"
        normalized="$(dirname "$p")"
      elif [[ "${p,,}" == *.iso ]]; then
        type="ISO"
        normalized="$p"
      elif is_video "$p"; then
        type="VIDEO"
        normalized="$p"
      else
        continue
      fi
      if [[ -z "${SCAN_SEEN[$normalized]:-}" ]]; then
        SCAN_SEEN["$normalized"]=1
        SCAN_TYPES+=("$type")
        SCAN_ITEMS+=("$normalized")
      fi
    done < <(find "$target" \
      \( -path "$target/proc" -o -path "$target/proc/*" -o -path "$target/sys" -o -path "$target/sys/*" -o -path "$target/dev" -o -path "$target/dev/*" -o -path "$target/run" -o -path "$target/run/*" -o -path "$target/tmp" -o -path "$target/tmp/*" \) -prune -o \
      \( -type f \( -iname '*.mkv' -o -iname '*.mp4' -o -iname '*.avi' -o -iname '*.mov' -o -iname '*.ts' -o -iname '*.m2ts' -o -iname '*.wmv' -o -iname '*.webm' -o -iname '*.mpg' -o -iname '*.mpeg' -o -iname '*.iso' \) -print -o -type d -name BDMV -print \) 2>/dev/null)
  fi
}

show_results() {
  local total="${#SCAN_ITEMS[@]}"
  local show_n i label

  if (( total == 0 )); then
    screen "$(msg none)"
    screen "$(msg none_hint)"
    return 1
  fi

  show_n=$(( total > MAX_SCAN_DISPLAY ? MAX_SCAN_DISPLAY : total ))
  for ((i=1; i<=show_n; i++)); do
    case "${SCAN_TYPES[i-1]}" in
      VIDEO) label="$(msg type_video)" ;;
      BDMV) label="$(msg type_bdmv)" ;;
      ISO) label="$(msg type_iso)" ;;
      *) label="${SCAN_TYPES[i-1]}" ;;
    esac
    printf "%d) [%s] %s\n" "$i" "$label" "${SCAN_ITEMS[i-1]}"
  done
  if (( total > MAX_SCAN_DISPLAY )); then
    screen "$(msg limit)"
  fi
  return 0
}

generate_item() {
  local type="$1"
  local src="$2"
  local safe out
  local has_error=0

  resolve_source_output_layout "$type" "$src" || {
    screen_error "输出路径计算失败：$type $src"
    return 1
  }
  mkdir -p "$BDTOOL_SOURCE_INFO_ROOT"
  safe="$(safe_name "$BDTOOL_SOURCE_GEN_NAME")"
  out="$(unique_dir "$BDTOOL_SOURCE_INFO_ROOT" "$safe")"
  dbg "output root=$BDTOOL_SOURCE_INFO_ROOT dir=$out type=$type src=$src"
  mkdir -p "$out"

  if [[ "$type" == "VIDEO" ]]; then
    if require_runtime_cmd mediainfo; then
      if ! mediainfo "$src" > "$out/mediainfo_1.txt" 2>/dev/null; then
        echo "mediainfo 执行失败" > "$out/mediainfo_1.txt"
        has_error=1
      fi
    else
      echo "未安装 mediainfo，无法生成有效信息。" > "$out/mediainfo_1.txt"
      has_error=1
    fi

    if require_runtime_cmd ffmpeg && require_runtime_cmd ffprobe; then
      local duration dur_int i sec
      duration="$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$src" 2>/dev/null || true)"
      dur_int="${duration%.*}"
      [[ "$dur_int" =~ ^[0-9]+$ ]] || dur_int=60
      (( dur_int < 12 )) && dur_int=12
      for i in 1 2 3 4 5 6; do
        sec=$(( (dur_int * i) / 7 ))
        if ! ffmpeg -hide_banner -loglevel error -ss "$sec" -i "$src" -frames:v 1 -y "$out/截图_$i.png" >/dev/null 2>&1; then
          has_error=1
        fi
      done
    else
      has_error=1
    fi
    ensure_six_png "$out"
    finalize_video_output "$out" || has_error=1
  else
    if require_runtime_cmd BDInfo; then
      if [[ "$type" == "BDMV" ]]; then
        if ! BDInfo -w "$src/BDMV" "$out" > "$out/BDInfo_1.txt" 2>/dev/null; then
          echo "BDInfo 执行失败" > "$out/BDInfo_1.txt"
          has_error=1
        fi
      else
        if ! BDInfo -w "$src" "$out" > "$out/BDInfo_1.txt" 2>/dev/null; then
          echo "BDInfo 执行失败" > "$out/BDInfo_1.txt"
          has_error=1
        fi
      fi
      find "$out" -maxdepth 1 -type f ! -name 'BDInfo_1.txt' -delete
    else
      echo "未安装 BDInfo，使用占位信息。" > "$out/BDInfo_1.txt"
      has_error=1
    fi
  fi

  if [[ "$has_error" -eq 0 ]]; then
    screen "$(msg gen_done)$out"
    screen "$(msg op_ok)"
  else
    screen "$(msg gen_done)$out"
    screen_error "$(msg op_fail)"
  fi
  LAST_OUTPUT_DIR="$out"
}

download_item() {
  local out="$1"
  local parent="${2:-}"
  local base src_parent zip_path tar_path
  src_parent="$(dirname "$out")"
  if [[ -z "$parent" ]]; then
    parent="$(resolve_default_download_dir)" || return 1
  fi
  mkdir -p "$parent"
  base="$(basename "$out")"
  zip_path="$parent/$base.zip"
  tar_path="$parent/$base.tar.gz"

  if command -v zip >/dev/null 2>&1; then
    (cd "$src_parent" && zip -qr "$zip_path" "$base") || return 1
    screen "$(msg downloaded)$zip_path"
    return 0
  fi

  tar -czf "$tar_path" -C "$src_parent" "$base" || return 1
  screen "$(msg downloaded)$tar_path"
  return 0
}

ask_download_dir() {
  local out_var="$1"
  local input=""
  local default_dir=""
  default_dir="$(resolve_default_download_dir)" || return 1
  if read_line "$(msg download_dir_prompt): " input; then
    if [[ -z "$input" ]]; then
      printf -v "$out_var" '%s' "$default_dir"
    else
      printf -v "$out_var" '%s' "$input"
    fi
  else
    printf -v "$out_var" '%s' "$default_dir"
  fi
}

cleanup_item() {
  local out="$1"
  if [[ -e "$out" ]]; then
    rm -rf "$out"
    screen "$(msg cleaned)$out"
  else
    screen "$(msg clean_missing)$out"
  fi
}

post_process_item() {
  local out="$1"
  local c retries

  retries=0
  while (( retries < 3 )); do
    section "$(msg post_title)"
    menu_option "$(msg post_1)"
    menu_option "$(msg post_2)"
    menu_option "$(msg post_0)"
    menu_option "$(msg post_9)"
    read_line "$(msg prompt): " c || return 0
    case "$c" in
      1)
        local download_dir=""
        ask_download_dir download_dir
        if download_item "$out" "$download_dir"; then
          screen "$(msg op_ok)"
          screen "$(msg post_hint_next)"
        else
          screen_error "$(msg op_fail)"
        fi
        ;;
      2)
        if cleanup_item "$out"; then
          screen "$(msg op_ok)"
        else
          screen_error "$(msg op_fail)"
        fi
        ;;
      0|"")
        return 0
        ;;
      9|q|Q)
        BDTOOL_EXIT_REQUESTED=1
        return 0
        ;;
      *)
        retries=$((retries + 1))
        screen_error "$(msg invalid)"
        ;;
    esac
  done

  screen "$(msg pick_limit)"
  return 0
}

handle_multi_select() {
  local raw="$1"
  local tokens t idx
  local -A seen=()
  local -a selected=()

  read -r -a tokens <<< "$raw"
  if [[ "${#tokens[@]}" -eq 1 && "${tokens[0]}" == "0" ]]; then
    return 1
  fi

  for t in "${tokens[@]}"; do
    [[ "$t" =~ ^[0-9]+$ ]] || return 2
    idx="$t"
    if (( idx <= 0 || idx > MAX_SCAN_DISPLAY || idx > ${#SCAN_ITEMS[@]} )); then
      return 2
    fi
    if [[ -z "${seen[$idx]:-}" ]]; then
      seen[$idx]=1
      selected+=("$idx")
    fi
  done

  if (( ${#selected[@]} == 0 )); then
    return 2
  fi

  for idx in "${selected[@]}"; do
    generate_item "${SCAN_TYPES[idx-1]}" "${SCAN_ITEMS[idx-1]}"
    post_process_item "$LAST_OUTPUT_DIR"
    if [[ "$BDTOOL_EXIT_REQUESTED" == "1" ]]; then
      return 0
    fi
  done

  return 0
}

scan_flow() {
  local target="$1"
  local full="$2"
  local pick retries rc

  collect_results "$target" "$full"
  show_results || return 0

  retries=0
  while (( retries < 3 )); do
    read_line "$(msg pick): " pick || return 0
    handle_multi_select "$pick"
    rc=$?
    [[ "$BDTOOL_EXIT_REQUESTED" == "1" ]] && return 0
    if [[ "$rc" -eq 0 || "$rc" -eq 1 ]]; then
      return 0
    fi
    retries=$((retries + 1))
    screen_error "$(msg invalid)"
  done

  screen "$(msg pick_limit)"
  return 0
}

scan_menu() {
  local c p retry
  while true; do
    section "$(msg scan_title)"
    menu_option "$(msg scan_1)"
    menu_option "$(msg scan_2)"
    menu_option "$(msg scan_0)"
    read_line "$(msg prompt): " c || return 0
    case "$c" in
      1)
        screen "$(msg scan_warn_1)"
        screen "$(msg scan_warn_2)"
        read_line "$(msg scan_confirm): " c || return 0
        c="$(echo "$c" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
        dbg "full-scan confirm input='$c'"
        if [[ "$c" == "1" || "${c,,}" == "y" || "${c,,}" == "yes" ]]; then
          dbg "full-scan confirmed -> entering scan_flow"
          scan_flow "/" "1"
          [[ "$BDTOOL_EXIT_REQUESTED" == "1" ]] && return 0
        else
          dbg "full-scan canceled -> back to scan menu"
        fi
        ;;
      2)
        retry=0
        while (( retry < 3 )); do
          read_line "$(msg dir_prompt): " p || return 0
          if [[ -d "$p" && -r "$p" ]]; then
            scan_flow "$p" "0"
            [[ "$BDTOOL_EXIT_REQUESTED" == "1" ]] && return 0
            break
          fi
          retry=$((retry + 1))
          if [[ "$p" != /* ]]; then
            screen_error "$(msg dir_invalid)（请使用绝对路径，例如 /home/$USER/Downloads）"
          elif [[ ! -e "$p" ]]; then
            screen_error "$(msg dir_invalid)（路径不存在：$p；示例：/home/$USER/Downloads）"
          elif [[ -f "$p" && -x "$p" ]]; then
            screen_error "$(msg dir_exec_file)"
          elif [[ ! -d "$p" ]]; then
            screen_error "$(msg dir_invalid)（不是目录：$p；示例：/home/$USER/Downloads）"
          else
            screen_error "$(msg dir_invalid)（目录不可读：$p）"
          fi
        done
        ;;
      0) return 0 ;;
      *) screen_error "$(msg invalid)" ;;
    esac
  done
}

main_menu() {
  local c
  while true; do
    section "$(msg main_title)"
    menu_option "$(msg main_1)"
    menu_option "$(msg main_2)"
    menu_option "$(msg main_3)"
    read_line "$(msg prompt): " c || return 0
    case "$c" in
      1) scan_menu ;;
      2)
        if [[ "$LANG_CODE" == "zh" ]]; then LANG_CODE="en"; else LANG_CODE="zh"; fi
        ;;
      3|9|q|Q)
        screen "$(msg bye)"
        return 0
        ;;
      *) screen_error "$(msg invalid)" ;;
    esac
  done
}

main() {
  # Prefer script CLI mode when called with a direct target path/command.
  # This preserves menu UX for plain `bdtool` while making `bdtool <path>`
  # and compatibility commands execute real processing.
  if [[ $# -gt 0 ]]; then
    case "$1" in
      scan|doctor|status|install|clean|start|version|--version|-v|help)
        if [[ -x "$ROOT_DIR/bdtool.sh" ]]; then
          exec "$ROOT_DIR/bdtool.sh" "$@"
        fi
        screen_error "找不到 CLI 脚本：$ROOT_DIR/bdtool.sh"
        exit 127
        ;;
      *)
        if [[ -e "$1" ]]; then
          if [[ -x "$ROOT_DIR/bdtool.sh" ]]; then
            exec "$ROOT_DIR/bdtool.sh" "$@"
          fi
          screen_error "找不到 CLI 脚本：$ROOT_DIR/bdtool.sh"
          exit 127
        fi
        ;;
    esac
  fi

  local lang=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lang)
        lang="${2:-}"
        shift 2
        ;;
      --lang=*)
        lang="${1#*=}"
        shift
        ;;
      --non-interactive)
        BDTOOL_NO_PROMPT=1
        shift
        ;;
      --help|-h)
        if [[ "$LANG_CODE" == "en" ]]; then
          echo "Usage: bdtool [--lang zh|en]"
        else
          echo "用法: bdtool [--lang zh|en]"
        fi
        exit 0
        ;;
      *)
        shift
        ;;
    esac
  done

  if [[ -n "$lang" ]]; then
    if [[ "$lang" == "en" ]]; then LANG_CODE="en"; else LANG_CODE="zh"; fi
  fi

  if [[ "$BDTOOL_NO_PROMPT" == "1" ]]; then
    if [[ "$LANG_CODE" == "en" ]]; then
      echo "Usage: bdtool [--lang zh|en]"
    else
      echo "用法: bdtool [--lang zh|en]"
    fi
    exit 0
  fi

  main_menu
}

main "$@"
require_runtime_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 && return 0
  screen_error "缺少依赖命令：$cmd"
  screen_error "请先执行：bash scripts/fetch-deps.sh && bash scripts/build-bundle.sh，然后重新安装离线包。"
  return 1
}
