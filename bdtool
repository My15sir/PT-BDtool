#!/usr/bin/env bash
set -Euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/ui.sh
source "$ROOT_DIR/lib/ui.sh"
# shellcheck source=lib/i18n.sh
source "$ROOT_DIR/lib/i18n.sh"

: "${BDTOOL_NO_PROMPT:=0}"
: "${BDTOOL_CMD_TIMEOUT:=300}"

ensure_output_root

TASK_TEMP_DIRS=()

on_err() {
  local rc=$?
  write_error_file "unexpected error (rc=${rc})" "请重试；若持续失败，请检查依赖并重新安装。"
  screen_error "$(t ERR_HINT_FILE)$ERROR_FILE"
  exit "$rc"
}

trap on_err ERR
trap 'write_error_file "interrupted" "重新执行命令。"; exit 130' INT TERM

read_line() {
  local prompt="$1"
  local __out_var="$2"
  local line=""

  if [[ "$BDTOOL_NO_PROMPT" == "1" ]]; then
    return 1
  fi

  if [[ -t 0 ]]; then
    read -r -p "$prompt" line || return 1
  elif [[ -p /dev/stdin ]]; then
    IFS= read -r line || return 1
  elif [[ -t 1 && -r /dev/tty ]]; then
    read -r -p "$prompt" line < /dev/tty || return 1
  else
    return 1
  fi

  printf -v "$__out_var" '%s' "$line"
  return 0
}

safe_name() {
  local s="$1"
  s="${s//\//_}"
  s="${s// /_}"
  s="$(echo "$s" | tr -cd '[:alnum:]_.-')"
  [[ -n "$s" ]] || s="item"
  printf "%s" "$s"
}

short_hash() {
  local input="$1"
  if command -v sha1sum >/dev/null 2>&1; then
    echo -n "$input" | sha1sum | awk '{print substr($1,1,8)}'
  else
    date +%s | tail -c 8
  fi
}

is_video() {
  case "${1,,}" in
    *.mkv|*.mp4|*.avi|*.mov|*.ts|*.m2ts|*.wmv|*.webm|*.mpg|*.mpeg) return 0 ;;
    *) return 1 ;;
  esac
}

create_task_context() {
  local tid="task_$(date +%Y%m%d_%H%M%S)_$RANDOM"
  local cache_dir="$OUTPUT_ROOT/cache/$tid"
  mkdir -p "$cache_dir"
  TASK_TEMP_DIRS+=("$cache_dir")
  LAST_TASK_CACHE_DIR="$cache_dir"
}

create_placeholder_png() {
  local dst="$1"
  if command -v base64 >/dev/null 2>&1; then
    printf 'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMBAAZ/qT8AAAAASUVORK5CYII=' | base64 -d > "$dst" 2>/dev/null || : > "$dst"
  else
    : > "$dst"
  fi
}

ensure_six_png() {
  local info_dir="$1"
  local last_file=""
  local i

  for i in 1 2 3 4 5 6; do
    if [[ -f "$info_dir/$i.png" ]]; then
      last_file="$info_dir/$i.png"
      break
    fi
  done

  for i in 1 2 3 4 5 6; do
    if [[ ! -f "$info_dir/$i.png" ]]; then
      if [[ -n "$last_file" && -f "$last_file" ]]; then
        cp -f "$last_file" "$info_dir/$i.png" 2>/dev/null || create_placeholder_png "$info_dir/$i.png"
      else
        create_placeholder_png "$info_dir/$i.png"
        last_file="$info_dir/$i.png"
      fi
    fi
  done
}

generate_mediainfo_file() {
  local src="$1"
  local out="$2"
  if command -v mediainfo >/dev/null 2>&1; then
    run_ext "$BDTOOL_CMD_TIMEOUT" mediainfo "$src" > "$out" 2>&1 || echo "mediainfo 执行失败" > "$out"
  elif command -v ffprobe >/dev/null 2>&1; then
    run_ext "$BDTOOL_CMD_TIMEOUT" ffprobe -v error -show_streams -show_format "$src" > "$out" 2>&1 || echo "ffprobe 执行失败" > "$out"
  else
    echo "未安装 mediainfo/ffprobe，使用占位信息。" > "$out"
  fi
}

generate_bdinfo_file() {
  local src="$1"
  local out="$2"
  local target="$src"

  if [[ -d "$src/BDMV" ]]; then
    target="$src/BDMV"
  fi

  if command -v BDInfo >/dev/null 2>&1; then
    run_ext "$BDTOOL_CMD_TIMEOUT" BDInfo -w "$target" "$(dirname "$out")" > "$out" 2>&1 || echo "BDInfo 执行失败" > "$out"
  else
    echo "未安装 BDInfo，使用占位信息。" > "$out"
  fi
}

generate_video_shots() {
  local src="$1"
  local info_dir="$2"

  if command -v ffmpeg >/dev/null 2>&1 && command -v ffprobe >/dev/null 2>&1; then
    local duration dur_int i sec
    duration="$(run_ext "$BDTOOL_CMD_TIMEOUT" ffprobe -v error -show_entries format=duration -of csv=p=0 "$src" 2>/dev/null || true)"
    dur_int="${duration%.*}"
    [[ "$dur_int" =~ ^[0-9]+$ ]] || dur_int=60
    (( dur_int < 12 )) && dur_int=12

    for i in 1 2 3 4 5 6; do
      sec=$(( (dur_int * i) / 7 ))
      run_ext "$BDTOOL_CMD_TIMEOUT" ffmpeg -hide_banner -loglevel error -ss "$sec" -i "$src" -frames:v 1 -y "$info_dir/$i.png" >/dev/null 2>&1 || true
    done
  fi

  ensure_six_png "$info_dir"
}

collect_scan_items() {
  local target="$1"
  local full="$2"

  if [[ "$full" == "1" ]]; then
    run_ext "$BDTOOL_CMD_TIMEOUT" find / -xdev \
      \( -path /proc -o -path /proc/* -o -path /sys -o -path /sys/* -o -path /dev -o -path /dev/* -o -path /run -o -path /run/* -o -path /tmp -o -path /tmp/* \) -prune -o \
      \( -type f \( -iname '*.mkv' -o -iname '*.mp4' -o -iname '*.avi' -o -iname '*.mov' -o -iname '*.ts' -o -iname '*.m2ts' -o -iname '*.wmv' -o -iname '*.webm' -o -iname '*.mpg' -o -iname '*.mpeg' -o -iname '*.iso' \) -print -o -type d -name BDMV -print \) 2>/dev/null
  else
    run_ext "$BDTOOL_CMD_TIMEOUT" find "$target" -xdev \
      \( -path "$target/proc" -o -path "$target/proc/*" -o -path "$target/sys" -o -path "$target/sys/*" -o -path "$target/dev" -o -path "$target/dev/*" -o -path "$target/run" -o -path "$target/run/*" -o -path "$target/tmp" -o -path "$target/tmp/*" \) -prune -o \
      \( -type f \( -iname '*.mkv' -o -iname '*.mp4' -o -iname '*.avi' -o -iname '*.mov' -o -iname '*.ts' -o -iname '*.m2ts' -o -iname '*.wmv' -o -iname '*.webm' -o -iname '*.mpg' -o -iname '*.mpeg' -o -iname '*.iso' \) -print -o -type d -name BDMV -print \) 2>/dev/null
  fi
}

build_scan_list() {
  local target="$1"
  local full="$2"
  local list_file="$3"

  : > "$list_file"
  local p t
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    if [[ "${p##*/}" == "BDMV" && -d "$p" ]]; then
      t="BDMV"
      p="$(dirname "$p")"
    elif [[ "${p,,}" == *.iso ]]; then
      t="ISO"
    elif is_video "$p"; then
      t="VIDEO"
    else
      continue
    fi
    printf "%s|%s\n" "$t" "$p" >> "$list_file"
  done < <(collect_scan_items "$target" "$full")

  awk -F'|' '!seen[$2]++' "$list_file" > "$list_file.tmp" && mv -f "$list_file.tmp" "$list_file"
}

show_scan_results() {
  local list_file="$1"
  local -n type_ref=$2
  local -n path_ref=$3

  type_ref=()
  path_ref=()

  local line type path count=0
  section "$(t SCAN_RESULTS)"
  while IFS='|' read -r type path; do
    [[ -n "$type" && -n "$path" ]] || continue
    type_ref+=("$type")
    path_ref+=("$path")
    count=$((count + 1))
    if (( count <= 50 )); then
      printf "%d) [%s] %s\n" "$count" "$type" "$path"
    fi
  done < "$list_file"

  if (( count == 0 )); then
    screen "$(t SCAN_NONE)"
    return 1
  fi

  if (( count > 50 )); then
    screen "$(t SCAN_MORE)"
  fi

  return 0
}

generate_for_item() {
  local type="$1"
  local src="$2"

  local base safe out_dir info_dir
  base="$(basename "$src")"
  safe="$(safe_name "$base")_$(short_hash "$src")"
  out_dir="$OUTPUT_ROOT/$safe"
  info_dir="$out_dir/信息"

  mkdir -p "$info_dir"

  if [[ "$type" == "VIDEO" ]]; then
    generate_mediainfo_file "$src" "$info_dir/mediainfo.txt"
    generate_video_shots "$src" "$info_dir"
  else
    generate_bdinfo_file "$src" "$info_dir/bdinfo.txt"
    ensure_six_png "$info_dir"
  fi

  screen "$(t GEN_DONE)$out_dir"
  post_generate_menu "$safe" "$out_dir"
}

download_result() {
  local safe="$1"
  local out_dir="$2"

  local dl_dir="$HOME/Downloads/PT-BDtool"
  mkdir -p "$dl_dir"

  local pkg=""
  if command -v zip >/dev/null 2>&1; then
    pkg="$dl_dir/${safe}.zip"
    (cd "$(dirname "$out_dir")" && run_ext "$BDTOOL_CMD_TIMEOUT" zip -qr "$pkg" "$(basename "$out_dir")") || return 1
  else
    pkg="$dl_dir/${safe}.tar.gz"
    (cd "$(dirname "$out_dir")" && run_ext "$BDTOOL_CMD_TIMEOUT" tar -czf "$pkg" "$(basename "$out_dir")") || return 1
  fi

  screen "$(t DL_DONE)$pkg"
  return 0
}

cleanup_task_temp() {
  local p
  for p in "${TASK_TEMP_DIRS[@]:-}"; do
    [[ -n "$p" ]] || continue
    case "$p" in
      "$OUTPUT_ROOT"/cache/*) rm -rf "$p" 2>/dev/null || true ;;
      *) ;;
    esac
  done
}

post_generate_menu() {
  local safe="$1"
  local out_dir="$2"

  while true; do
    menu_option "$(t POST_MENU_1)"
    menu_option "$(t POST_MENU_2)"

    local pick=""
    read_line "$(t POST_PROMPT): " pick || return 0
    case "$pick" in
      1)
        if download_result "$safe" "$out_dir"; then
          screen "$(t CLEAN_TMP_PROMPT)"
          menu_option "$(t CLEAN_TMP_1)"
          menu_option "$(t CLEAN_TMP_2)"
          local cpick=""
          read_line "$(t POST_PROMPT): " cpick || cpick="2"
          if [[ "$cpick" == "1" ]]; then
            cleanup_task_temp
          fi
          screen "$(t ALL_DONE)"
          return 0
        else
          write_error_file "package creation failed" "请检查 zip/tar 命令后重试。"
          screen_error "$(t ERR_HINT_FILE)$ERROR_FILE"
          return 1
        fi
        ;;
      2)
        return 0
        ;;
      *)
        screen_error "$(t MENU_INVALID)"
        ;;
    esac
  done
}

select_and_generate() {
  local list_file="$1"
  local -a types=()
  local -a paths=()

  show_scan_results "$list_file" types paths || return 0

  local attempts=0
  local pick=""
  while (( attempts < 3 )); do
    read_line "$(t SCAN_PICK): " pick || return 0

    if [[ "$pick" == "0" ]]; then
      return 0
    fi

    if [[ "$pick" =~ ^[0-9]+$ ]] && (( pick >= 1 && pick <= ${#types[@]} )); then
      generate_for_item "${types[pick-1]}" "${paths[pick-1]}"
      return 0
    fi

    attempts=$((attempts + 1))
    screen_error "$(t SCAN_PICK_INVALID)"
  done

  screen "$(t SCAN_PICK_LIMIT)"
  return 0
}

run_scan_flow() {
  local target="$1"
  local full="$2"

  local task_cache
  create_task_context
  task_cache="$LAST_TASK_CACHE_DIR"
  local list_file="$task_cache/scan.list"

  build_scan_list "$target" "$full" "$list_file"
  select_and_generate "$list_file"
}

scan_menu() {
  while true; do
    section "$(t SCAN_TITLE)"
    menu_option "$(t SCAN_MENU_1)"
    menu_option "$(t SCAN_MENU_2)"
    menu_option "$(t SCAN_MENU_0)"

    local c=""
    read_line "$(t MENU_PROMPT): " c || return 0

    case "$c" in
      1)
        screen "$(t SCAN_WARN_1)"
        screen "$(t SCAN_WARN_2)"
        screen "$(t SCAN_WARN_3)"
        local confirm=""
        read_line "$(t SCAN_CONFIRM_FULL): " confirm || confirm="0"
        [[ "$confirm" == "1" ]] || continue
        run_scan_flow "/" "1"
        ;;
      2)
        local d=""
        while true; do
          read_line "$(t SCAN_DIR_PROMPT): " d || return 0
          if [[ -d "$d" && -r "$d" ]]; then
            run_scan_flow "$d" "0"
            break
          fi
          screen_error "$(t SCAN_DIR_INVALID)"
        done
        ;;
      0)
        return 0
        ;;
      *)
        screen_error "$(t MENU_INVALID)"
        ;;
    esac
  done
}

switch_lang() {
  if [[ "$LANG_CODE" == "zh" ]]; then
    set_lang "en"
    screen "$(t LANG_SW_TO_EN)"
  else
    set_lang "zh"
    screen "$(t LANG_SW_TO_ZH)"
  fi
}

show_help() {
  screen "$(t HELP_TEXT)"
}

main_menu() {
  while true; do
    section "$(t MENU_TITLE)"
    menu_option "$(t MENU_1)"
    menu_option "$(t MENU_2)"
    menu_option "$(t MENU_3)"

    local choice=""
    read_line "$(t MENU_PROMPT): " choice || return 0

    case "$choice" in
      1) scan_menu ;;
      2) switch_lang ;;
      3|q|Q) return 0 ;;
      *) screen_error "$(t MENU_INVALID)" ;;
    esac
  done
}

main() {
  local lang_override=""
  local cmd=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lang)
        [[ $# -ge 2 ]] || { show_help; return 1; }
        lang_override="$2"
        shift 2
        ;;
      --lang=*)
        lang_override="${1#*=}"
        shift
        ;;
      --non-interactive)
        export BDTOOL_NO_PROMPT=1
        shift
        ;;
      --help|-h)
        cmd="help"
        shift
        ;;
      scan)
        cmd="scan"
        shift
        ;;
      *)
        shift
        ;;
    esac
  done

  set_lang "$lang_override"

  case "$cmd" in
    help)
      show_help
      ;;
    scan)
      if [[ "$BDTOOL_NO_PROMPT" == "1" ]]; then
        show_help
      else
        scan_menu
      fi
      ;;
    *)
      if [[ "$BDTOOL_NO_PROMPT" == "1" ]]; then
        show_help
      else
        main_menu
      fi
      ;;
  esac
}

main "$@"
