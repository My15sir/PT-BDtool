read_line() {
  local prompt="$1"
  local __out="$2"
  local line=""

  if [[ "$BDTOOL_NO_PROMPT" == "1" ]]; then
    return 1
  fi

  if [[ -t 0 ]]; then
    read -r -p "$prompt" line || return 1
  elif [[ ! -t 0 ]]; then
    IFS= read -r line || return 1
  elif [[ -t 1 && -r /dev/tty ]]; then
    read -r -p "$prompt" line < /dev/tty || return 1
  else
    return 1
  fi

  printf -v "$__out" '%s' "$line"
  return 0
}

safe_name() {
  local n="$1"
  n="${n// /_}"
  n="$(echo "$n" | tr -cd '[:alnum:]_.-')"
  [[ -n "$n" ]] || n="unknown"
  echo "${n:0:64}"
}

unique_dir() {
  local info_root="$1"
  local base="$2"
  local out="$info_root/$base"
  local idx=2
  while [[ -e "$out" ]]; do
    out="$info_root/${base}_$idx"
    idx=$((idx + 1))
  done
  echo "$out"
}

resolve_fixed_output_root() {
  local type="$1"
  local src="$2"
  resolve_source_output_layout "$type" "$src" || return 1
  printf "%s" "$(dirname "$BDTOOL_SOURCE_INFO_ROOT")/PT-BDtool"
}

create_placeholder_png() {
  local dst="$1"
  if command -v base64 >/dev/null 2>&1; then
    printf 'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMBAAZ/qT8AAAAASUVORK5CYII=' | base64 -d > "$dst" 2>/dev/null || : > "$dst"
  else
    : > "$dst"
  fi
}

ensure_six_png() {
  local dir="$1"
  local last=""
  local i
  for i in 1 2 3 4 5 6; do
    if [[ -f "$dir/截图_$i.png" ]]; then
      last="$dir/截图_$i.png"
      break
    fi
  done
  for i in 1 2 3 4 5 6; do
    if [[ ! -f "$dir/截图_$i.png" ]]; then
      if [[ -n "$last" && -f "$last" ]]; then
        cp -f "$last" "$dir/截图_$i.png" 2>/dev/null || create_placeholder_png "$dir/截图_$i.png"
      else
        create_placeholder_png "$dir/截图_$i.png"
        last="$dir/截图_$i.png"
      fi
    fi
  done
}

finalize_video_output() {
  local dir="$1"
  local keep_re='^截图_[1-6]\.png$|^mediainfo_1\.txt$'
  local file cnt
  for file in "$dir"/*; do
    [[ -f "$file" ]] || continue
    if [[ ! "$(basename "$file")" =~ $keep_re ]]; then
      rm -f -- "$file"
    fi
  done
  cnt="$(find "$dir" -maxdepth 1 -type f | wc -l | tr -d ' ')"
  [[ "$cnt" == "7" ]] || return 1
  return 0
}

is_video() {
  case "${1,,}" in
    *.mkv|*.mp4|*.avi|*.mov|*.ts|*.m2ts|*.wmv|*.webm|*.mpg|*.mpeg) return 0 ;;
    *) return 1 ;;
  esac
}

is_audio() {
  case "${1,,}" in
    *.mp3|*.flac|*.wav|*.m4a|*.aac|*.ogg|*.opus) return 0 ;;
    *) return 1 ;;
  esac
}

finalize_audio_output() {
  local dir="$1"
  local keep_re='^频谱图_1\.png$|^mediainfo_1\.txt$'
  local file cnt
  for file in "$dir"/*; do
    [[ -f "$file" ]] || continue
    if [[ ! "$(basename "$file")" =~ $keep_re ]]; then
      rm -f -- "$file"
    fi
  done
  cnt="$(find "$dir" -maxdepth 1 -type f | wc -l | tr -d ' ')"
  [[ "$cnt" == "2" ]] || return 1
  return 0
}

pick_disc_probe_video() {
  local src="$1"
  local candidate=""
  if [[ -d "$src/BDMV/STREAM" ]]; then
    candidate="$(find "$src/BDMV/STREAM" -type f -iname '*.m2ts' -printf '%s %p\n' 2>/dev/null | sort -nr | head -n1 | cut -d' ' -f2- || true)"
  elif [[ -d "$src/STREAM" ]]; then
    candidate="$(find "$src/STREAM" -type f -iname '*.m2ts' -printf '%s %p\n' 2>/dev/null | sort -nr | head -n1 | cut -d' ' -f2- || true)"
  elif [[ -f "$src" ]]; then
    candidate="$src"
  fi
  printf "%s" "$candidate"
}

make_disc_screenshots() {
  local src="$1"
  local out="$2"
  local probe duration dur_int i sec
  probe="$(pick_disc_probe_video "$src")"
  if [[ -n "$probe" ]] && require_runtime_cmd ffmpeg && require_runtime_cmd ffprobe; then
    duration="$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$probe" 2>/dev/null || true)"
    dur_int="${duration%.*}"
    [[ "$dur_int" =~ ^[0-9]+$ ]] || dur_int=60
    (( dur_int < 12 )) && dur_int=12
    for i in 1 2 3 4 5 6; do
      sec=$(( (dur_int * i) / 7 ))
      ffmpeg -nostdin -hide_banner -loglevel error -ss "$sec" -i "$probe" -frames:v 1 -y "$out/截图_$i.png" >/dev/null 2>&1 || true
    done
  fi
  ensure_six_png "$out"
}

finalize_disc_output() {
  local dir="$1"
  local keep_re='^截图_[1-6]\.png$|^BDInfo_1\.txt$'
  local file cnt i
  bdinfo_report_valid "$dir/BDInfo_1.txt" || return 1
  for i in 1 2 3 4 5 6; do
    [[ -s "$dir/截图_$i.png" ]] || return 1
  done
  for file in "$dir"/*; do
    [[ -f "$file" ]] || continue
    if [[ ! "$(basename "$file")" =~ $keep_re ]]; then
      rm -f -- "$file"
    fi
  done
  cnt="$(find "$dir" -maxdepth 1 -type f | wc -l | tr -d ' ')"
  [[ "$cnt" == "7" ]] || return 1
  return 0
}

collect_results() {
  local target="$1"
  local full="$2"
  local p type normalized root tmp_candidates total processed pct last_pct

  normalize_scan_root() {
    local in="${1:-/}"
    [[ -n "$in" ]] || in="/"
    while [[ "$in" != "/" && "$in" == */ ]]; do
      in="${in%/}"
    done
    printf "%s" "$in"
  }

  SCAN_TYPES=()
  SCAN_ITEMS=()
  unset SCAN_SEEN
  declare -gA SCAN_SEEN=()

  if [[ "$full" == "1" ]]; then
    root="$(normalize_scan_root "${BDTOOL_SCAN_FULL_ROOT:-/}")"
    screen "扫描中：全盘扫描（$root）"
    screen "扫描进度: 0%"
    tmp_candidates="$(mktemp)"
    find "$root" \
      \( -path "$root/proc" -o -path "$root/proc/*" -o -path "$root/sys" -o -path "$root/sys/*" -o -path "$root/dev" -o -path "$root/dev/*" -o -path "$root/run" -o -path "$root/run/*" -o -path "$root/tmp" -o -path "$root/tmp/*" \) -prune -o \
      \( -type f \( -iname '*.mkv' -o -iname '*.mp4' -o -iname '*.avi' -o -iname '*.mov' -o -iname '*.ts' -o -iname '*.m2ts' -o -iname '*.wmv' -o -iname '*.webm' -o -iname '*.mpg' -o -iname '*.mpeg' -o -iname '*.iso' -o -iname '*.mp3' -o -iname '*.flac' -o -iname '*.wav' -o -iname '*.m4a' -o -iname '*.aac' -o -iname '*.ogg' -o -iname '*.opus' \) -print -o -type d -name BDMV -print \) 2>/dev/null > "$tmp_candidates" || true
    total="$(wc -l < "$tmp_candidates" | tr -d ' ')"
    processed=0
    last_pct=0
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      processed=$((processed + 1))
      if [[ "${total:-0}" -gt 0 ]]; then
        pct=$((processed * 100 / total))
        if [[ "$pct" -ge 100 ]]; then pct=100; fi
        if (( pct >= last_pct + 10 || pct == 100 )); then
          screen "扫描进度: ${pct}%"
          last_pct="$pct"
        fi
      fi
      if [[ "${p##*/}" == "BDMV" && -d "$p" ]]; then
        type="BDMV"
        normalized="$(dirname "$p")"
      elif [[ "${p,,}" == *.iso ]]; then
        type="ISO"
        normalized="$p"
      elif is_video "$p"; then
        type="VIDEO"
        normalized="$p"
      elif is_audio "$p"; then
        type="AUDIO"
        normalized="$p"
      else
        continue
      fi
      if [[ -z "${SCAN_SEEN[$normalized]:-}" ]]; then
        SCAN_SEEN["$normalized"]=1
        SCAN_TYPES+=("$type")
        SCAN_ITEMS+=("$normalized")
      fi
    done < "$tmp_candidates"
    rm -f "$tmp_candidates"
  else
    root="$(normalize_scan_root "$target")"
    screen "扫描中：目录扫描（$root）"
    screen "扫描进度: 0%"
    tmp_candidates="$(mktemp)"
    find "$root" \
      \( -path "$root/proc" -o -path "$root/proc/*" -o -path "$root/sys" -o -path "$root/sys/*" -o -path "$root/dev" -o -path "$root/dev/*" -o -path "$root/run" -o -path "$root/run/*" -o -path "$root/tmp" -o -path "$root/tmp/*" \) -prune -o \
      \( -type f \( -iname '*.mkv' -o -iname '*.mp4' -o -iname '*.avi' -o -iname '*.mov' -o -iname '*.ts' -o -iname '*.m2ts' -o -iname '*.wmv' -o -iname '*.webm' -o -iname '*.mpg' -o -iname '*.mpeg' -o -iname '*.iso' -o -iname '*.mp3' -o -iname '*.flac' -o -iname '*.wav' -o -iname '*.m4a' -o -iname '*.aac' -o -iname '*.ogg' -o -iname '*.opus' \) -print -o -type d -name BDMV -print \) 2>/dev/null > "$tmp_candidates" || true
    total="$(wc -l < "$tmp_candidates" | tr -d ' ')"
    processed=0
    last_pct=0
    while IFS= read -r p; do
      [[ -n "$p" ]] || continue
      processed=$((processed + 1))
      if [[ "${total:-0}" -gt 0 ]]; then
        pct=$((processed * 100 / total))
        if [[ "$pct" -ge 100 ]]; then pct=100; fi
        if (( pct >= last_pct + 10 || pct == 100 )); then
          screen "扫描进度: ${pct}%"
          last_pct="$pct"
        fi
      fi
      if [[ "${p##*/}" == "BDMV" && -d "$p" ]]; then
        type="BDMV"
        normalized="$(dirname "$p")"
      elif [[ "${p,,}" == *.iso ]]; then
        type="ISO"
        normalized="$p"
      elif is_video "$p"; then
        type="VIDEO"
        normalized="$p"
      elif is_audio "$p"; then
        type="AUDIO"
        normalized="$p"
      else
        continue
      fi
      if [[ -z "${SCAN_SEEN[$normalized]:-}" ]]; then
        SCAN_SEEN["$normalized"]=1
        SCAN_TYPES+=("$type")
        SCAN_ITEMS+=("$normalized")
      fi
    done < "$tmp_candidates"
    rm -f "$tmp_candidates"
  fi
  if (( last_pct < 100 )); then
    screen "扫描进度: 100%"
  fi
  screen "扫描完成：共发现 ${#SCAN_ITEMS[@]} 个候选"
}

show_results() {
  local total="${#SCAN_ITEMS[@]}"
  local show_n i label

  if (( total == 0 )); then
    screen "$(msg none)"
    screen "$(msg none_hint)"
    return 1
  fi

  show_n=$(( total > MAX_SCAN_DISPLAY ? MAX_SCAN_DISPLAY : total ))
  for ((i=1; i<=show_n; i++)); do
    case "${SCAN_TYPES[i-1]}" in
      VIDEO) label="$(msg type_video)" ;;
      AUDIO) label="$(msg type_audio)" ;;
      BDMV) label="$(msg type_bdmv)" ;;
      ISO) label="$(msg type_iso)" ;;
      *) label="${SCAN_TYPES[i-1]}" ;;
    esac
    printf "%d) [%s] %s\n" "$i" "$label" "${SCAN_ITEMS[i-1]}"
  done
  if (( total > MAX_SCAN_DISPLAY )); then
    screen "$(msg limit)"
  fi
  return 0
}

generate_item() {
  local type="$1"
  local src="$2"
  local safe out
  local has_error=0
  local hard_fail=0

  resolve_source_output_layout "$type" "$src" || {
    screen_error "输出路径计算失败：$type $src"
    return 1
  }
  out="$(resolve_fixed_output_root "$type" "$src" || true)"
  [[ -n "$out" ]] || {
    screen_error "输出路径计算失败：$type $src"
    return 1
  }
  dbg "output root=$BDTOOL_SOURCE_INFO_ROOT dir=$out type=$type src=$src"
  mkdir -p "$out"
  screen "生成中：$src"

  if [[ "$type" == "VIDEO" ]]; then
    if require_runtime_cmd mediainfo; then
      if ! mediainfo "$src" > "$out/mediainfo_1.txt" 2>/dev/null; then
        echo "mediainfo 执行失败" > "$out/mediainfo_1.txt"
        hard_fail=1
      fi
    else
      echo "未安装 mediainfo，无法生成有效信息。" > "$out/mediainfo_1.txt"
      hard_fail=1
    fi

    if require_runtime_cmd ffmpeg && require_runtime_cmd ffprobe; then
      local duration dur_int i sec
      duration="$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$src" 2>/dev/null || true)"
      dur_int="${duration%.*}"
      [[ "$dur_int" =~ ^[0-9]+$ ]] || dur_int=60
      (( dur_int < 12 )) && dur_int=12
      for i in 1 2 3 4 5 6; do
        sec=$(( (dur_int * i) / 7 ))
        if ! ffmpeg -nostdin -hide_banner -loglevel error -ss "$sec" -i "$src" -frames:v 1 -y "$out/截图_$i.png" >/dev/null 2>&1; then
          has_error=1
        fi
      done
    else
      hard_fail=1
    fi
    ensure_six_png "$out"
    finalize_video_output "$out" || hard_fail=1
  elif [[ "$type" == "AUDIO" ]]; then
    if require_runtime_cmd mediainfo; then
      if ! mediainfo "$src" > "$out/mediainfo_1.txt" 2>/dev/null; then
        echo "mediainfo 执行失败" > "$out/mediainfo_1.txt"
        hard_fail=1
      fi
    else
      echo "未安装 mediainfo，无法生成有效信息。" > "$out/mediainfo_1.txt"
      hard_fail=1
    fi

    if require_runtime_cmd ffmpeg; then
      if ! ffmpeg -nostdin -hide_banner -loglevel error -y -i "$src" -lavfi "showspectrumpic=s=1600x900:legend=disabled" -frames:v 1 "$out/频谱图_1.png" >/dev/null 2>&1; then
        hard_fail=1
      fi
    else
      hard_fail=1
    fi
    finalize_audio_output "$out" || hard_fail=1
  else
    if require_runtime_cmd BDInfo; then
      local bd_source="$src"
      local bd_stdout_tmp=""
      local bd_report=""
      if [[ "$type" == "BDMV" ]]; then
        bd_source="$src/BDMV"
      fi
      bd_stdout_tmp="$out/.bdinfo_stdout_$$.txt"
      rm -f "$out/BDInfo_1.txt" "$bd_stdout_tmp"
      if ! BDInfo -w "$bd_source" "$out" > "$bd_stdout_tmp" 2>/dev/null; then
        screen_error "BDInfo 执行失败：$bd_source"
        hard_fail=1
      else
        if bdinfo_report_valid "$bd_stdout_tmp"; then
          bd_report="$bd_stdout_tmp"
        else
          bd_report="$(find_valid_bdinfo_report "$out" || true)"
        fi
        if [[ -z "$bd_report" ]]; then
          screen_error "BDInfo 输出无效：缺少 playlist/clip/video/audio/stream 核心字段"
          hard_fail=1
        else
          if [[ "$bd_report" != "$out/BDInfo_1.txt" ]]; then
            cp -f "$bd_report" "$out/BDInfo_1.txt" || hard_fail=1
          fi
          if ! bdinfo_report_valid "$out/BDInfo_1.txt"; then
            screen_error "BDInfo 输出无效：$out/BDInfo_1.txt"
            hard_fail=1
          fi
          find "$out" -maxdepth 1 -type f -name '*.txt' ! -name 'BDInfo_1.txt' -delete
        fi
      fi
      rm -f "$bd_stdout_tmp"
      if [[ "$hard_fail" -eq 0 ]]; then
        make_disc_screenshots "$src" "$out"
        finalize_disc_output "$out" || hard_fail=1
      fi
    else
      hard_fail=1
    fi
  fi

  has_error="$hard_fail"

  if [[ "$has_error" -eq 0 ]]; then
    screen "生成完成"
    screen "$(msg gen_done)$out"
    screen "$(msg op_ok)"
    LAST_OUTPUT_DIR="$out"
    return 0
  else
    screen_error "步骤失败：生成阶段校验未通过（$type）"
    screen "$(msg gen_done)$out"
    screen_error "$(msg op_fail)"
    LAST_OUTPUT_DIR="$out"
    return 1
  fi
}

download_item() {
  local out="$1"
  local parent="${2:-}"
  local base src_parent zip_path tar_path
  src_parent="$(dirname "$out")"
  if [[ -z "$parent" ]]; then
    parent="$(resolve_default_download_dir)" || return 1
  fi
  mkdir -p "$parent"
  base="$(basename "$out")"
  zip_path="$parent/$base.zip"
  tar_path="$parent/$base.tar.gz"

  if command -v zip >/dev/null 2>&1; then
    screen "打包进度: 0%"
    screen "打包进度: 30%"
    (cd "$src_parent" && zip -qr "$zip_path" "$base") || return 1
    screen "打包进度: 100%"
    screen "$(msg downloaded)$zip_path"
    return 0
  fi

  screen "打包进度: 0%"
  screen "打包进度: 30%"
  tar -czf "$tar_path" -C "$src_parent" "$base" || return 1
  screen "打包进度: 100%"
  screen "$(msg downloaded)$tar_path"
  return 0
}

ask_download_dir() {
  local out_var="$1"
  local input=""
  local default_dir=""
  default_dir="$(resolve_default_download_dir)" || return 1
  if read_line "$(msg download_dir_prompt): " input; then
    if [[ -z "$input" ]]; then
      printf -v "$out_var" '%s' "$default_dir"
    else
      printf -v "$out_var" '%s' "$input"
    fi
  else
    printf -v "$out_var" '%s' "$default_dir"
  fi
}

cleanup_item() {
  local out="$1"
  if [[ -e "$out" ]]; then
    rm -rf "$out"
    screen "$(msg cleaned)$out"
  else
    screen "$(msg clean_missing)$out"
  fi
}

post_process_item() {
  local out="$1"
  local c=""
  local download_dir=""
  local default_action="${BDTOOL_POST_ACTION:-}"
  download_dir="$(resolve_default_download_dir)" || {
    screen_error "步骤失败：无法解析默认下载目录"
    screen_error "$(msg op_fail)"
    return 1
  }

  if download_item "$out" "$download_dir"; then
    screen "$(msg op_ok)"
    if cleanup_item "$out" >/dev/null 2>&1; then
      screen "$(msg cleaned)$out"
    else
      screen_error "步骤失败：清理阶段失败（$out）"
      screen_error "$(msg op_fail)"
      return 1
    fi
  else
    screen_error "步骤失败：打包/下载阶段失败（$out）"
    screen_error "$(msg op_fail)"
    return 1
  fi

  # Auto flow completed; do not block waiting for extra input.
  section "$(msg post_title)"
  menu_option "$(msg post_0)"
  menu_option "$(msg post_9)"
  if [[ -n "$default_action" ]]; then
    c="$default_action"
  else
    c="0"
  fi
  case "$c" in
    9|q|Q)
      BDTOOL_EXIT_REQUESTED=1
      screen "$(msg bye)"
      return 0
      ;;
    0|"")
      return 0
      ;;
    *)
      return 0
      ;;
  esac
  return 0
}

handle_multi_select() {
  local raw="$1"
  local tokens t idx
  local -A seen=()
  local -a selected=()

  read -r -a tokens <<< "$raw"
  if [[ "${#tokens[@]}" -eq 1 && "${tokens[0]}" == "0" ]]; then
    return 1
  fi

  for t in "${tokens[@]}"; do
    [[ "$t" =~ ^[0-9]+$ ]] || return 2
    idx="$t"
    if (( idx <= 0 || idx > MAX_SCAN_DISPLAY || idx > ${#SCAN_ITEMS[@]} )); then
      return 2
    fi
    if [[ -z "${seen[$idx]:-}" ]]; then
      seen[$idx]=1
      selected+=("$idx")
    fi
  done

  if (( ${#selected[@]} == 0 )); then
    return 2
  fi

  for idx in "${selected[@]}"; do
    if ! generate_item "${SCAN_TYPES[idx-1]}" "${SCAN_ITEMS[idx-1]}"; then
      return 2
    fi
    if ! post_process_item "$LAST_OUTPUT_DIR"; then
      return 2
    fi
    if [[ "$BDTOOL_EXIT_REQUESTED" == "1" ]]; then
      return 0
    fi
  done

  return 0
}

scan_flow() {
  local target="$1"
  local full="$2"
  local pick retries rc

  collect_results "$target" "$full"
  show_results || return 0

  retries=0
  while (( retries < 3 )); do
    read_line "$(msg pick): " pick || return 0
    handle_multi_select "$pick"
    rc=$?
    [[ "$BDTOOL_EXIT_REQUESTED" == "1" ]] && return 0
    if [[ "$rc" -eq 0 || "$rc" -eq 1 ]]; then
      return 0
    fi
    retries=$((retries + 1))
    screen_error "$(msg invalid)"
  done

  screen "$(msg pick_limit)"
  return 0
}

scan_menu() {
  scan_flow "/" "1"
  return 0
}

main_menu() {
  local c
  while true; do
    section "$(msg main_title)"
    menu_option "$(msg main_1)"
    menu_option "$(msg main_2)"
    menu_option "$(msg main_3)"
    read_line "$(msg prompt): " c || return 0
    case "$c" in
      1|/) scan_menu; [[ "$BDTOOL_EXIT_REQUESTED" == "1" ]] && return 0 ;;
      2)
        if [[ "$LANG_CODE" == "zh" ]]; then LANG_CODE="en"; else LANG_CODE="zh"; fi
        ;;
      3|9|q|Q)
        screen "$(msg bye)"
        return 0
        ;;
      *) screen_error "$(msg invalid)" ;;
    esac
  done
}

main() {
  # Prefer script CLI mode when called with a direct target path/command.
  # This preserves menu UX for plain `bdtool` while making `bdtool <path>`
  # and compatibility commands execute real processing.
  if [[ $# -gt 0 ]]; then
    case "$1" in
      scan|doctor|status|install|clean|start|version|--version|-v|help)
        if [[ -x "$ROOT_DIR/bdtool.sh" ]]; then
          exec "$ROOT_DIR/bdtool.sh" "$@"
        fi
        screen_error "找不到 CLI 脚本：$ROOT_DIR/bdtool.sh"
        exit 127
        ;;
      *)
        if [[ -e "$1" ]]; then
          if [[ -x "$ROOT_DIR/bdtool.sh" ]]; then
            exec "$ROOT_DIR/bdtool.sh" "$@"
          fi
          screen_error "找不到 CLI 脚本：$ROOT_DIR/bdtool.sh"
          exit 127
        fi
        ;;
    esac
  fi

  local lang=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lang)
        lang="${2:-}"
        shift 2
        ;;
      --lang=*)
        lang="${1#*=}"
        shift
        ;;
      --non-interactive)
        BDTOOL_NO_PROMPT=1
        shift
        ;;
      --help|-h)
        if [[ "$LANG_CODE" == "en" ]]; then
          echo "Usage: bdtool [--lang zh|en]"
        else
          echo "用法: bdtool [--lang zh|en]"
        fi
        exit 0
        ;;
      *)
        shift
        ;;
    esac
  done

  if [[ -n "$lang" ]]; then
    if [[ "$lang" == "en" ]]; then LANG_CODE="en"; else LANG_CODE="zh"; fi
  fi

  if [[ "$BDTOOL_NO_PROMPT" == "1" ]]; then
    if [[ "$LANG_CODE" == "en" ]]; then
      echo "Usage: bdtool [--lang zh|en]"
    else
      echo "用法: bdtool [--lang zh|en]"
    fi
    exit 0
  fi

  main_menu
}

require_runtime_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 && return 0
  if [[ "$cmd" == "ffmpeg" ]]; then
    screen_error "缺少依赖命令：ffmpeg"
    screen_error "可复制修复：apt-get update && apt-get install -y ffmpeg mediainfo"
    return 1
  fi
  if [[ "$cmd" == "BDInfo" ]]; then
    screen_error "缺少依赖命令：BDInfo"
    screen_error "请先执行：bash install.sh --offline"
    return 1
  fi
  screen_error "缺少依赖命令：$cmd"
  screen_error "请先执行：bash install.sh --offline"
  return 1
}

main "$@"
