#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BDTOOL_ROOT="$ROOT_DIR"
export BDTOOL_ROOT
: "${BDTOOL_NO_PROMPT:=0}"
: "${MENU_LOG_TAIL:=80}"

# shellcheck source=lib/ui.sh
source "$ROOT_DIR/lib/ui.sh"
# shellcheck source=lib/i18n.sh
source "$ROOT_DIR/lib/i18n.sh"

ensure_log_dir "$ROOT_DIR"
setup_log_redirection "$ROOT_DIR"

CLI_LANG_OVERRIDE=""
if [[ $# -gt 0 ]]; then
  idx=1
  while [[ "$idx" -le "$#" ]]; do
    arg="${!idx}"
    if [[ "$arg" == "--lang" ]]; then
      next=$((idx + 1))
      if [[ "$next" -le "$#" ]]; then
        CLI_LANG_OVERRIDE="${!next}"
      fi
      idx=$((idx + 2))
      continue
    elif [[ "$arg" == --lang=* ]]; then
      CLI_LANG_OVERRIDE="${arg#*=}"
    fi
    idx=$((idx + 1))
  done
fi

set_lang "$CLI_LANG_OVERRIDE"
if ! i18n_normalize_lang "$LANG_CODE" >/dev/null 2>&1; then
  set_lang "zh"
fi

trap 'error "$(t ERR_UNCAUGHT)"; error "$(t LOG_PATH): $BDTOOL_RUN_LOG"' ERR

APP_VERSION="dev"
if command -v git >/dev/null 2>&1; then
  APP_VERSION="$(cd "$ROOT_DIR" && git rev-parse --short HEAD 2>/dev/null || echo dev)"
fi
GITHUB_URL="https://github.com/My15sir/PT-BDtool"

show_banner() {
  section "PT-BDtool"
  echo " ____ ______   ____  ____           _ "
  echo "|  _ \\_   _| | __ )|  _ \\ ___  ___| |"
  echo "| |_) || |   |  _ \\| |_) / _ \\/ __| |"
  echo "|  __/ | |   | |_) |  _ <  __/\\__ \\_|"
  echo "|_|    |_|   |____/|_| \\_\\___||___(_)"
  info "$(t APP_TITLE)"
  info "$(t APP_SUBTITLE)"
  info "Version: $APP_VERSION"
  info "GitHub: $GITHUB_URL"
}

show_help() {
  show_banner
  hr
  echo "$(t HELP_TITLE):"
  echo "  bdtool [--lang zh|en]"
  echo "  bdtool --help [--lang zh|en]"
  echo "  bdtool install [--non-interactive] [--lang zh|en]"
  echo "  bdtool doctor [--lang zh|en]"
  echo "  bdtool scan [path] [--lang zh|en] [extra scan args]"
  echo "  bdtool clean [--yes] [--lang zh|en]"
  echo "  bdtool logs [--tail N] [--lang zh|en]"
  echo
  echo "$(t HELP_DESC)"
  echo "$(t HELP_NONTTY_POLICY)"
  echo
  echo "$(t HELP_COMMANDS):"
  echo "  install"
  echo "  doctor"
  echo "  scan"
  echo "  clean"
  echo "  logs"
  echo
  echo "Options:"
  echo "  --lang zh|en         $(t HELP_OPT_LANG)"
  echo "  --non-interactive    $(t HELP_OPT_NONINT)"
  echo "  --yes                $(t HELP_OPT_YES)"
  echo "  --tail N             $(t HELP_OPT_TAIL)"
}

die_with_hint() {
  error "$1"
  hint "$(t HINT_USE_HELP)"
  die "$(t LOG_PATH): $BDTOOL_RUN_LOG"
}

cmd_install() {
  local non_interactive=0
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --non-interactive)
        non_interactive=1
        shift
        ;;
      --lang|--lang=*)
        if [[ "$1" == "--lang" ]]; then
          [[ $# -ge 2 ]] || die_with_hint "$(t ERR_NEED_VALUE)"
          set_lang "$2"
          shift 2
        else
          set_lang "${1#*=}"
          shift
        fi
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  if [[ "$non_interactive" -eq 1 ]]; then
    export BDTOOL_NO_PROMPT=1
  fi
  execute_with_spinner "$(t INSTALL_RUNNING)" "$ROOT_DIR/install.sh" "${args[@]}" || die "$(t INSTALL_RUNNING) failed"
}

cmd_doctor() {
  execute_with_spinner "$(t DOCTOR_RUNNING)" "$ROOT_DIR/bdtool.sh" doctor || die "$(t DOCTOR_RUNNING) failed"
}

cmd_scan() {
  local scan_path="${1:-.}"
  shift || true
  execute_with_spinner "$(t SCAN_RUNNING)" "$ROOT_DIR/bdtool.sh" scan "$scan_path" "$@" || die "$(t SCAN_RUNNING) failed"
}

cmd_clean() {
  local yes=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes) yes=1; shift ;;
      *) shift ;;
    esac
  done

  if [[ "$yes" -ne 1 ]]; then
    if [[ "${BDTOOL_NO_PROMPT:-0}" == "1" || ! -t 1 ]]; then
      die "$(t ERR_NONINT_NEED_YES)"
    fi
    confirm "$(t CONFIRM_CLEAN_1)" "N" || return 0
    confirm "$(t CONFIRM_CLEAN_2)" "N" || return 0
  fi
  execute_with_spinner "$(t CLEAN_RUNNING)" "$ROOT_DIR/bdtool.sh" clean || die "$(t CLEAN_RUNNING) failed"
}

cmd_logs() {
  local tail_n="${1:-$MENU_LOG_TAIL}"
  validate_int_range "$tail_n" 1 10000 || die_with_hint "$(t ERR_LOG_TAIL_INT)"
  section "$(t LOGS_RUNNING)"
  tail -n "$tail_n" "$BDTOOL_RUN_LOG"
}

switch_language() {
  if [[ "$LANG_CODE" == "zh" ]]; then
    set_lang "en"
    success "$(t MENU_SWITCHED_EN)"
  else
    set_lang "zh"
    success "$(t MENU_SWITCHED_ZH)"
  fi
}

has_scan_capability() {
  [[ -x "$ROOT_DIR/bdtool.sh" ]] || return 1
  grep -qE '^[[:space:]]*scan\)' "$ROOT_DIR/bdtool.sh" 2>/dev/null
}

menu_pause() {
  info "$(t PRESS_ENTER_RETURN)"
  if [[ -t 0 ]]; then
    read -r -p "" _ || true
  else
    IFS= read -r _ || true
  fi
}

ux_append() {
  {
    printf "[%s] %s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$*"
  } >> "$BDTOOL_UX_LOG"
}

run_action() {
  local label_key="$1"
  shift

  local label
  label="$(t "$label_key")"

  section "$label"
  ux_append "[ACTION] $label | cmd: $*"

  local rc=0
  local old_err_trap
  old_err_trap="$(trap -p ERR || true)"

  trap - ERR
  set +e
  _run_command_with_timeout "${BDTOOL_CMD_TIMEOUT:-300}" "$@" >> "$BDTOOL_UX_LOG" 2>&1
  rc=$?
  set -e
  if [[ -n "$old_err_trap" ]]; then
    eval "$old_err_trap"
  fi

  ux_append "[ACTION-END] $label | rc=$rc"

  if [[ "$rc" -eq 0 ]]; then
    success "$(t ACTION_SUCCESS_PREFIX)${label}$(t ACTION_DONE_SUFFIX)"
  else
    error "$(t ACTION_FAIL_PREFIX)${label}$(t ACTION_FAIL_SUFFIX)${BDTOOL_UX_LOG}"
  fi

  menu_pause
  return 0
}

run_logs_action() {
  local tail_n="${MENU_LOG_TAIL:-80}"
  section "$(t LOGS_RUNNING)"
  ux_append "[ACTION] $(t LOGS_RUNNING) | tail=$tail_n | run_log=$BDTOOL_RUN_LOG"

  if validate_int_range "$tail_n" 1 10000 && [[ -f "$BDTOOL_RUN_LOG" ]]; then
    tail -n "$tail_n" "$BDTOOL_RUN_LOG"
    success "$(t ACTION_SUCCESS_PREFIX)$(t LOGS_RUNNING)$(t ACTION_DONE_SUFFIX)"
  else
    error "$(t ACTION_FAIL_PREFIX)$(t LOGS_RUNNING)$(t ACTION_FAIL_SUFFIX)${BDTOOL_UX_LOG}"
  fi

  menu_pause
}

menu_loop() {
  while true; do
    show_banner
    hr
    color_menu_option "$(t MENU_1)"
    color_menu_option "$(t MENU_2)"
    color_menu_option "$(t MENU_3)"
    color_menu_option "$(t MENU_4)"
    color_menu_option "$(t MENU_5)"
    color_menu_option "$(t MENU_6)"
    color_menu_option "$(t MENU_7)"
    hr

    local choice
    if [[ -t 0 ]]; then
      if ! read -r -p "$(t MENU_PROMPT): " choice; then
        info "$(t MENU_BYE)"
        return 0
      fi
    else
      if ! IFS= read -r choice; then
        info "$(t MENU_BYE)"
        return 0
      fi
    fi

    case "$choice" in
      1) run_action INSTALL_RUNNING "$ROOT_DIR/install.sh" --non-interactive --lang "$LANG_CODE" ;;
      2) run_action DOCTOR_RUNNING "$ROOT_DIR/bdtool.sh" doctor ;;
      3)
        if has_scan_capability; then
          run_action SCAN_RUNNING "$ROOT_DIR/bdtool.sh" scan . --mode dry
        else
          warn "$(t MENU_SCAN_NA)"
          menu_pause
        fi
        ;;
      4)
        if confirm "$(t CONFIRM_CLEAN_1)" "N" && confirm "$(t CONFIRM_CLEAN_2)" "N"; then
          run_action CLEAN_RUNNING "$ROOT_DIR/bdtool.sh" clean
        else
          menu_pause
        fi
        ;;
      5) run_logs_action ;;
      6) switch_language ;;
      7|q|Q)
        info "$(t MENU_BYE)"
        return 0
        ;;
      *)
        error "$(t MENU_INVALID)"
        ;;
    esac
  done
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lang)
        [[ $# -ge 2 ]] || die_with_hint "$(t ERR_NEED_VALUE)"
        set_lang "$2"
        shift 2
        ;;
      --lang=*)
        set_lang "${1#*=}"
        shift
        ;;
      --non-interactive)
        export BDTOOL_NO_PROMPT=1
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    if [[ "${BDTOOL_NO_PROMPT:-0}" != "1" && ( -t 0 || -p /dev/stdin ) ]]; then
      menu_loop
      return 0
    fi
    info "$(t MSG_NONTTY_HELP)"
    show_help
    return 0
  fi

  local cmd="$1"
  shift || true

  case "$cmd" in
    -h|--help|help)
      show_help
      ;;
    install)
      cmd_install "$@"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    scan)
      cmd_scan "$@"
      ;;
    clean)
      cmd_clean "$@"
      ;;
    logs)
      if [[ "${1:-}" == "--tail" ]]; then
        shift
        cmd_logs "${1:-$MENU_LOG_TAIL}"
      elif [[ "${1:-}" == --tail=* ]]; then
        cmd_logs "${1#*=}"
      else
        cmd_logs "$MENU_LOG_TAIL"
      fi
      ;;
    *)
      die_with_hint "unknown command: $cmd"
      ;;
  esac
}

main "$@"
